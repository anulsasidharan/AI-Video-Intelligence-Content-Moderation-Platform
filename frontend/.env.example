# Backend API base URL (without trailing slash). Use "" for same-origin /api/v1 (browser → Next.js → rewrite).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side only: where Next.js rewrites /api/v1/* (Docker/ECS internal URL). If unset, falls back to NEXT_PUBLIC_API_URL.
# Example when NEXT_PUBLIC_API_URL is "": API_UPSTREAM_URL=http://backend:8000
# API_UPSTREAM_URL=

# WebSocket URL for real-time updates
NEXT_PUBLIC_WS_URL=http://localhost:8000

# S3 bucket domain for images (optional — used for next/image domain allow-list)
S3_BUCKET_DOMAIN=

# App environment
NEXT_PUBLIC_APP_ENV=development
