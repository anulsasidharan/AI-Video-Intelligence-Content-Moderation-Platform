# ── App ──────────────────────────────────────────────────────
APP_NAME=VidShield AI
APP_ENV=development
DEBUG=true

# ── Uvicorn (behind ALB / reverse proxy) ────────────────────
# Comma-separated IPs/CIDRs that may set X-Forwarded-Proto / X-Forwarded-For,
# or * to trust all immediate clients (typical inside a private VPC with ALB only).
# Without this, redirects may use http:// and break HTTPS pages (mixed content).
FORWARDED_ALLOW_IPS=*

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vidshield
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/vidshield

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth / JWT ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── GCP ──────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=vidshield-videos
GCS_PRESIGNED_URL_EXPIRE=3600
# Path to service-account JSON key for local dev signed-URL generation.
# Leave blank on GKE — Workload Identity (ADC) handles signing automatically.
GCS_SERVICE_ACCOUNT_KEY_PATH=

# ── RTMP ingest ───────────────────────────────────────────────
RTMP_INGEST_HOST=ingest.vidshield.ai

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini

# ── Pinecone ─────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=vidshield-embeddings

# ── Sentry ───────────────────────────────────────────────────
SENTRY_DSN=

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard/billing?success=true
STRIPE_CANCEL_URL=http://localhost:3000/dashboard/billing?canceled=true
